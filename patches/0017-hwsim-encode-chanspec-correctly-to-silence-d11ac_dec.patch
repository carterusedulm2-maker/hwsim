From a2a6dcb14fa386a879aa1a3ce0cb760b4cb5ac28 Mon Sep 17 00:00:00 2001
From: Carter <carter@local>
Date: Wed, 22 Apr 2026 13:39:27 +0800
Subject: [PATCH] hwsim: encode chanspec correctly to silence d11ac_decchspec
 WARN

HWSIM_AP_CHANNEL=1 was being returned for the 'chanspec' iovar and as
bi->chanspec in BSS_INFO, but those fields expect a D11AC chanspec
encoding (BW + band bits), not a plain channel number. brcmu_d11ac_decchspec
hit Invalid chanspec 0x0001 -> WARN_ONCE during cfg80211_get_channel after
wlan1 register.

Add HWSIM_AP_CHANSPEC = 0x1001 (ch1 | BW_20 | BND_2G) and use it for
both the iovar GET and the bi->chanspec field. WLC_GET_CHANNEL keeps
returning the bare channel number which is correct for that dcmd.

Validation: dmesg fully clean (0 WARNs) through wlan1 up + hostapd
AP-ENABLED cycle.
---
 .../wireless/broadcom/brcm80211/brcmfmac/hwsim/hwsim_core.c | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/drivers/net/wireless/broadcom/brcm80211/brcmfmac/hwsim/hwsim_core.c b/drivers/net/wireless/broadcom/brcm80211/brcmfmac/hwsim/hwsim_core.c
index 2207b9ec3..aa600294e 100644
--- a/drivers/net/wireless/broadcom/brcm80211/brcmfmac/hwsim/hwsim_core.c
+++ b/drivers/net/wireless/broadcom/brcm80211/brcmfmac/hwsim/hwsim_core.c
@@ -62,6 +62,8 @@ struct hwsim_bcdc_dcmd {
 #define HWSIM_AP_MAC		"\x02\x00\x00\x48\x53\x10"
 #define HWSIM_AP_SSID		"HWSIM-AP"
 #define HWSIM_AP_CHANNEL	1
+/* D11AC chanspec encoding: ch | BW_20 (0x1000) | BND_2G (0x0000) */
+#define HWSIM_AP_CHANSPEC	0x1001
 #define HWSIM_AP_SIGNAL		(-50)
 #define HWSIM_VERSION_STR	"wl0: Oct 01 2024 brcmfmac-hwsim-1.0"
 #define HWSIM_CLMVER_STR	"API: 0.0 Data: hwsim.0"
@@ -365,7 +367,7 @@ static void hwsim_scan_work_fn(struct work_struct *work)
 	bi->capability = cpu_to_le16(0x0431); /* ESS | Privacy | Short Preamble | Short Slot */
 	bi->SSID_len = strlen(HWSIM_AP_SSID);
 	memcpy(bi->SSID, HWSIM_AP_SSID, bi->SSID_len);
-	bi->chanspec = cpu_to_le16(HWSIM_AP_CHANNEL);
+	bi->chanspec = cpu_to_le16(HWSIM_AP_CHANSPEC);
 	bi->RSSI = cpu_to_le16(HWSIM_AP_SIGNAL);
 	bi->phy_noise = -95;
 	bi->n_cap = 1;
@@ -596,7 +598,7 @@ static int hwsim_handle_get_var(struct hwsim_dev *dev,
 	/* --- Scan related --- */
 
 	if (strcmp(iovar, "chanspec") == 0) {
-		__le32 val = cpu_to_le32(HWSIM_AP_CHANNEL);
+		__le32 val = cpu_to_le32(HWSIM_AP_CHANSPEC);
 		hwsim_build_ok(dev, req, &val, sizeof(val));
 		return 0;
 	}
